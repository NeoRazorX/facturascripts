{% extends 'UI/Field/_wrapper.html.twig' %}

{% block input %}
    <input type="number" name="{{ c.inputName() }}" id="{{ c.inputId() }}" value="{{ c.valueAttr() }}"
           class="{{ c.inputCssClass('form-control') }}" step="{{ c.stepAttr() }}"
           {%- if c.minAttr() != '' %} min="{{ c.minAttr() }}"{% endif %}
           {%- if c.maxAttr() != '' %} max="{{ c.maxAttr() }}"{% endif %}
           {%- if c.getPlaceholder() %} placeholder="{{ c.getPlaceholder() }}"{% endif %}
           {%- if c.isRequired() %} required{% endif %}
           {%- if c.isReadOnly() %} readonly{% endif %}
           {%- if c.getTabIndex() >= 0 %} tabindex="{{ c.getTabIndex() }}"{% endif %}/>
{% endblock %}
