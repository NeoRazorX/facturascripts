{% extends "Master/MenuBgTemplate.html.twig" %}

{% block css %}
    {{ parent() }}
    <style>
        /* Scroll horizontal para nav-pills en móvil */
        @media (max-width: 991px) {
            #uiEditTabs {
                overflow-x: auto;
                overflow-y: hidden;
                -webkit-overflow-scrolling: touch;
                flex-wrap: nowrap !important;
            }

            #uiEditTabs .nav-link {
                white-space: nowrap;
            }

            #uiEditTabs::-webkit-scrollbar {
                height: 4px;
            }

            #uiEditTabs::-webkit-scrollbar-track {
                background: #f1f1f1;
            }

            #uiEditTabs::-webkit-scrollbar-thumb {
                background: #888;
                border-radius: 2px;
            }
        }
    </style>
{% endblock %}

{% block bodyHeaderOptions %}
    {{ parent() }}
    {% set pageData = fsc.getPageData() %}
    {% set model = fsc.getModel() %}
    <div class="container-fluid d-print-none">
        <div class="row">
            <div class="col pb-2">
                {# Breadcrumb móvil #}
                <nav aria-label="breadcrumb" class="d-block d-md-none">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#">{{ trans(pageData.menu) }}</a></li>
                        {% if pageData.submenu %}
                            <li class="breadcrumb-item"><a href="#">{{ trans(pageData.submenu) }}</a></li>
                        {% endif %}
                        <li class="breadcrumb-item">
                            <a href="{{ fsc.listUrl() }}">{{ trans(pageData.title) }}</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            {% if fsc.hasData and model %}
                                {{ model.primaryDescription() | raw }}
                            {% else %}
                                {{ trans('new') }}
                            {% endif %}
                        </li>
                    </ol>
                </nav>

                {# Botones cabecera izquierda #}
                <div class="btn-group">
                    <a href="{{ fsc.listUrl() }}" class="btn btn-sm btn-secondary">
                        <i class="fa-solid fa-list fa-fw" aria-hidden="true"></i>
                        <span class="d-none d-lg-inline-block">{{ trans('all') }}</span>
                    </a>
                    {% if fsc.hasData and model %}
                        <a href="{{ fsc.url() }}?code={{ model.primaryColumnValue() | url_encode }}"
                           class="btn btn-sm btn-secondary" title="{{ trans('refresh') }}">
                            <i class="fa-solid fa-redo" aria-hidden="true"></i>
                        </a>
                    {% else %}
                        <a href="{{ fsc.url() }}" class="btn btn-sm btn-secondary" title="{{ trans('refresh') }}">
                            <i class="fa-solid fa-redo" aria-hidden="true"></i>
                        </a>
                    {% endif %}
                </div>

                {# Botón Opciones #}
                <div class="btn-group">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-secondary me-3 dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="fa-solid fa-wrench fa-fw" aria-hidden="true"></i>
                            <span class="d-none d-lg-inline-block">{{ trans('options') }}</span>
                        </button>
                        <div class="dropdown-menu">
                            <h6 class="dropdown-header">{{ trans('options-button-header') }}</h6>
                            <a class="dropdown-item"
                               href="EditPageOption?code={{ pageData.name }}&url={{ fsc.url() | url_encode }}">
                                <i class="{{ pageData.icon }} fa-fw me-1" aria-hidden="true"></i>
                                {{ trans(pageData.title) }}
                            </a>
                            {% for panelName, panel in fsc.extraPanels() %}
                                <a class="dropdown-item"
                                   href="EditPageOption?code={{ panelName }}&url={{ fsc.url() | url_encode }}">
                                    <i class="{{ panel.icon() }} fa-fw me-1" aria-hidden="true"></i>
                                    {{ panel.title() }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Botón Nuevo #}
                {% if fsc.hasData %}
                    <a href="{{ fsc.url() }}" class="btn btn-sm btn-success ms-1">
                        <i class="fa-solid fa-plus fa-fw" aria-hidden="true"></i>
                        <span class="d-none d-lg-inline-block">{{ trans('new') }}</span>
                    </a>
                {% endif %}

                {# Botones extra inyectados por subclases de UIEditController #}
                {{ fsc.extraHeaderButtons() | raw }}

                {# Botón Imprimir #}
                {% if fsc.hasData and model %}
                    <div class="btn-group ms-1">
                        <a href="{{ fsc.url() }}?code={{ model.primaryColumnValue() | url_encode }}&_event=export&option={{ fsc.exportManager.defaultOption() }}"
                           target="_blank" class="btn btn-sm btn-secondary">
                            <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i>
                            <span class="d-none d-lg-inline-block">{{ trans('print') }}</span>
                        </a>
                        <button type="button" class="btn btn-sm btn-secondary dropdown-toggle dropdown-toggle-split"
                                data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="sr-only">{{ trans('more') }}</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end">
                            {% for key, option in fsc.exportManager.options() %}
                                {% if key != fsc.exportManager.defaultOption() %}
                                    <a href="{{ fsc.url() }}?code={{ model.primaryColumnValue() | url_encode }}&_event=export&option={{ key }}"
                                       target="_blank" class="dropdown-item">
                                        <i class="{{ option.icon }} fa-fw me-1" aria-hidden="true"></i>
                                        {{ trans(option.description) }}
                                    </a>
                                {% endif %}
                            {% endfor %}
                            <div class="dropdown-divider"></div>
                            <a href="#" class="dropdown-item" data-bs-toggle="modal"
                               data-bs-target="#uiEditAdvancedExportModal">
                                <i class="fa-solid fa-tools fa-fw me-1" aria-hidden="true"></i>
                                {{ trans('advanced') }}
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Título y descripción (escritorio) #}
            <div class="col-md-auto d-none d-md-block text-end">
                <h1 class="h5 mb-0">{{ trans(pageData.title) }}</h1>
                {% if fsc.hasData and model %}
                    <p class="text-info mb-3">{{ model.primaryDescription() | raw }}</p>
                {% else %}
                    <p class="text-info mb-3">{{ trans('new') }}</p>
                {% endif %}
            </div>

            <div class="col-md-auto d-none d-lg-block">
                {% set image = fsc.getImageUrl() %}
                {% if image is empty %}
                    <i class="{{ pageData.icon }} fa-3x" aria-hidden="true"></i>
                {% else %}
                    <img src="{{ image }}" alt="{{ fsc.title }}" class="img-thumbnail"/>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block body %}
    {{ parent() }}
    {% set pageData = fsc.getPageData() %}
    {% set model = fsc.getModel() %}
    {% set extraPanels = fsc.extraPanels() %}
    {% set panelListViews = fsc.panelListViews() %}
    {% set inlineListViews = fsc.inlineListViews() %}
    {% set hasMultiplePanels = extraPanels | length > 0 or panelListViews | length > 0 %}
    {% set activeTab = fsc.activeTab() %}

    <div class="container-fluid">
        <div class="row g-2">

            {# Columna izquierda: navegación de paneles (solo si hay paneles extra editables) #}
            {% if hasMultiplePanels %}
                <div class="col-12 col-lg-auto mt-lg-2">
                    <div class="nav nav-pills flex-row flex-lg-column overflow-x-auto" id="uiEditTabs"
                         role="tablist" style="white-space: nowrap;">

                        {# Panel principal #}
                        <a class="nav-link{{ activeTab == '__main__' ? ' active' : '' }} text-nowrap"
                           id="__main__-tab" data-bs-toggle="pill" href="#__main__"
                           role="tab" aria-controls="__main__" aria-expanded="true">
                            <i class="{{ pageData.icon }} fa-fw me-1 d-none d-lg-inline-block" aria-hidden="true"></i>
                            <span>{{ trans(pageData.title) }}</span>
                        </a>

                        {# Paneles extra (editables) #}
                        {% for panelName, panel in extraPanels %}
                            <a class="nav-link{{ activeTab == panelName ? ' active' : '' }} text-nowrap"
                               id="{{ panelName }}-tab" data-bs-toggle="pill" href="#{{ panelName }}"
                               role="tab" aria-controls="{{ panelName }}" aria-expanded="true">
                                <i class="{{ panel.icon() }} fa-fw me-1 d-none d-lg-inline-block" aria-hidden="true"></i>
                                <span>{{ panel.title() }}</span>
                            </a>
                        {% endfor %}

                        {# Vistas de lista como pestañas laterales #}
                        {% for panelName, panelView in panelListViews %}
                            {% set disable = panelView.settings.active ? '' : ' disabled' %}
                            <a class="nav-link{{ activeTab == panelName ? ' active' : '' }}{{ disable }} text-nowrap"
                               id="{{ panelName }}-tab" data-bs-toggle="pill" href="#{{ panelName }}"
                               role="tab" aria-controls="{{ panelName }}" aria-expanded="true">
                                <i class="{{ panelView.icon }} fa-fw me-1 d-none d-lg-inline-block" aria-hidden="true"></i>
                                <span>{{ trans(panelView.title) }}</span>
                                {% if panelView.count > 0 %}
                                    <span class="badge bg-secondary ms-1">{{ number(panelView.count, 0) }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Columna derecha: contenido #}
            {% set rightClass = hasMultiplePanels ? 'col-12 col-lg' : 'col-12' %}
            <div class="{{ rightClass }}">
                <div class="tab-content" id="uiEditTabsContent">

                    {# Tab principal: formulario de edición #}
                    {% set mainActive = (not hasMultiplePanels or activeTab == '__main__') ? ' show active' : '' %}
                    <div class="tab-pane fade{{ mainActive }}" id="__main__" role="tabpanel"
                         aria-labelledby="__main__-tab">

                        {# Alertas de validación #}
                        {% if fsc.hasErrors() %}
                            <div class="alert alert-danger py-2 mb-2">
                                <i class="fa-solid fa-circle-exclamation me-1" aria-hidden="true"></i>
                                {% for field, errs in fsc.errors() %}
                                    {% for err in errs %}
                                        <div>{{ err }}</div>
                                    {% endfor %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        <form method="post" enctype="multipart/form-data" onsubmit="animateSpinner('add')"
                              id="formUIEdit">
                            {{ formToken() }}
                            {% if model %}
                                <input type="hidden" name="code" value="{{ model.primaryColumnValue() }}">
                            {% endif %}
                            {% if hasMultiplePanels %}
                                <input type="hidden" name="activetab" value="__main__">
                            {% endif %}

                            <div class="card shadow">
                                <div class="card-body">
                                    <div class="row">
                                        {% for group in fsc.componentGroups() %}
                                            <div class="col-md-12">
                                                {% if group.title %}
                                                    <legend class="text-info mt-2 mb-1">{{ trans(group.title) }}</legend>
                                                {% endif %}
                                                <div class="row g-2{{ group.alignBottom ? ' align-items-end' : '' }}">
                                                    {% for fieldname, component in group.components %}
                                                        {% if component.isHidden() %}
                                                            {{ component.renderHidden() | raw }}
                                                        {% else %}
                                                            <div class="{{ component.colClass() }}">
                                                                {{ component.renderEdit() | raw }}
                                                            </div>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div class="card-footer p-2">
                                    <div class="row g-2">
                                        {% if fsc.hasData %}
                                            <div class="col-auto">
                                                <button type="button" class="btn btn-sm btn-danger"
                                                        onclick="uiEditDelete()">
                                                    <i class="fa-solid fa-trash-alt fa-fw" aria-hidden="true"></i>
                                                    <span class="d-none d-sm-inline-block">{{ trans('delete') }}</span>
                                                </button>
                                            </div>
                                        {% endif %}
                                        <div class="col text-center"></div>
                                        {% if fsc.hasData %}
                                            <div class="col-auto">
                                                <button class="btn btn-sm btn-secondary" type="reset">
                                                    <i class="fa-solid fa-undo fa-fw" aria-hidden="true"></i>
                                                    <span class="d-none d-sm-inline-block">{{ trans('undo') }}</span>
                                                </button>
                                            </div>
                                        {% endif %}
                                        <div class="col-auto">
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="fa-solid fa-floppy-disk fa-fw" aria-hidden="true"></i>
                                                <span class="d-none d-sm-inline-block">{{ trans('save') }}</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    {# Tabs de paneles extra #}
                    {% for panelName, panel in extraPanels %}
                        {% set panelActive = (activeTab == panelName) ? ' show active' : '' %}
                        <div class="tab-pane fade{{ panelActive }}" id="{{ panelName }}" role="tabpanel"
                             aria-labelledby="{{ panelName }}-tab">
                            <form method="post" enctype="multipart/form-data" onsubmit="animateSpinner('add')"
                                  id="form{{ panelName }}">
                                {{ formToken() }}
                                {% if model %}
                                    <input type="hidden" name="code" value="{{ model.primaryColumnValue() }}">
                                {% endif %}
                                <input type="hidden" name="activetab" value="{{ panelName }}">

                                <div class="card shadow">
                                    <div class="card-body">
                                        <div class="row">
                                            {% for fieldname, component in panel.components() %}
                                                {% if component.isHidden() %}
                                                    {# campo oculto: sin HTML visible #}
                                                {% else %}
                                                    <div class="{{ component.colClass() }}">
                                                        {{ component.renderEdit() | raw }}
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="card-footer p-2">
                                        <div class="row g-2">
                                            <div class="col text-center"></div>
                                            {% if fsc.hasData %}
                                                <div class="col-auto">
                                                    <button class="btn btn-sm btn-secondary" type="reset">
                                                        <i class="fa-solid fa-undo fa-fw" aria-hidden="true"></i>
                                                        <span class="d-none d-sm-inline-block">{{ trans('undo') }}</span>
                                                    </button>
                                                </div>
                                            {% endif %}
                                            <div class="col-auto">
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="fa-solid fa-floppy-disk fa-fw" aria-hidden="true"></i>
                                                    <span class="d-none d-sm-inline-block">{{ trans('save') }}</span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    {% endfor %}

                    {# Tabs de vistas de lista laterales #}
                    {% for panelName, panelView in panelListViews %}
                        {% if panelView.settings.active %}
                            {% set panelActive = (activeTab == panelName) ? ' show active' : '' %}
                            <div class="tab-pane fade{{ panelActive }}" id="{{ panelName }}" role="tabpanel"
                                 aria-labelledby="{{ panelName }}-tab">
                                {% do fsc.setCurrentView(panelName) %}
                                {{ include(panelView.template) }}
                            </div>
                        {% endif %}
                    {% endfor %}

                </div>
            </div>
        </div>

        {# Vistas inline (setInLine=true): se renderizan debajo del formulario. #}
        {% for listName, listView in inlineListViews %}
            {% if listView.settings.active %}
                {% do fsc.setCurrentView(listName) %}
                {{ include(listView.template) }}
            {% endif %}
        {% endfor %}
    </div>

    {# Modal + form de confirmación de borrado #}
    {% if fsc.hasData %}
        <form id="uiEditDeleteForm" method="post" onsubmit="animateSpinner('add')">
            {{ formToken() }}
            {% if model %}
                <input type="hidden" name="code" value="{{ model.primaryColumnValue() }}">
            {% endif %}
            <input type="hidden" name="_event" value="delete">
        </form>

        <div class="modal fade" id="uiEditDeleteModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fa-solid fa-trash-alt fa-fw me-1" aria-hidden="true"></i>
                            {{ trans('confirm-delete') }}
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="{{ trans('close') }}"></button>
                    </div>
                    <div class="modal-body">{{ trans('are-you-sure') }}</div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            <i class="fa-solid fa-times"></i> {{ trans('cancel') }}
                        </button>
                        <button type="button" class="btn btn-danger"
                                onclick="document.getElementById('uiEditDeleteForm').submit()">
                            <i class="fa-solid fa-check"></i> {{ trans('confirm') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {# Modal de exportación avanzada #}
    {% if fsc.hasData and model %}
        <form action="{{ fsc.url() }}" method="post" class="float-start" target="_blank"
              onsubmit="animateSpinner('add')">
            {{ formToken() }}
            <input type="hidden" name="code" value="{{ model.primaryColumnValue() }}">
            <input type="hidden" name="_event" value="export"/>
            <div class="modal fade" id="uiEditAdvancedExportModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fa-solid fa-tools fa-fw me-1" aria-hidden="true"></i>
                                {{ trans('advanced') }}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"
                                    aria-label="{{ trans('close') }}"></button>
                        </div>
                        <div class="modal-body text-start">
                            <div class="mb-3">
                                <select name="option" class="form-select">
                                    {% for key, opt in fsc.exportManager.options() %}
                                        <option value="{{ key }}">{{ trans(opt.description) }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-3">
                                {{ trans('format') }}
                                <select name="idformat" class="form-select">
                                    <option value="">{{ trans('default') }}</option>
                                    <option value="">------</option>
                                    {% for format in fsc.exportManager.getFormats(model) %}
                                        <option value="{{ format.id }}">{{ format.nombre }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-3">
                                {{ trans('language') }}
                                <select name="langcode" class="form-select">
                                    <option value="">{{ trans('default') }}</option>
                                    <option value="">------</option>
                                    {% for code, lang in i18n.getAvailableLanguages() %}
                                        <option value="{{ code }}">{{ lang }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    {{ trans('accept') }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function uiEditDelete() {
            new bootstrap.Modal(document.getElementById('uiEditDeleteModal')).show();
        }

        function uiEditSendEvent(eventName) {
            var form = document.getElementById('formUIEdit');
            if (!form) { return; }
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = '_event';
            input.value = eventName;
            form.appendChild(input);
            form.submit();
        }

        $(document).ready(function () {
            if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) === false) {
                $('input:visible, textarea:visible')
                    .filter(':not([readonly]):not([disabled]):not([type="hidden"]):not([type="checkbox"]):not([type="radio"])')
                    .first()
                    .focus();
            }

            {# Persistir el panel activo en el hash de la URL #}
            $('[data-bs-toggle="pill"]').on('shown.bs.tab', function (e) {
                window.location.hash = e.target.getAttribute('href');
            });

            if (window.location.hash) {
                var tab = document.querySelector('[href="' + window.location.hash + '"]');
                if (tab) {
                    new bootstrap.Tab(tab).show();
                }
            }
        });
    </script>
{% endblock %}
