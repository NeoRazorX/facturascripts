{% extends "Master/MenuBgTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    {{ parent() }}
    {% set pageData = fsc.getPageData() %}
    <div class="container-fluid d-print-none">
        <div class="row">
            <div class="col pb-2">
                <a href="NewFormaPago?codpago=new" class="btn btn-sm btn-success">
                    <i class="fa-solid fa-plus fa-fw" aria-hidden="true"></i>
                    <span class="d-none d-lg-inline-block">{{ trans('new') }}</span>
                </a>
            </div>
            <div class="col-md-auto d-none d-md-block text-end">
                <h1 class="h5 mb-0">{{ trans(pageData.title) }}</h1>
            </div>
            <div class="col-md-auto d-none d-lg-block">
                <i class="{{ pageData.icon }} fa-3x" aria-hidden="true"></i>
            </div>
        </div>
    </div>
{% endblock %}

{% block body %}
    {{ parent() }}
    <div class="container-fluid">
        {% set records = fsc.records() %}

        {% if records | length == 0 %}
            <div class="alert alert-info">
                <i class="fa-solid fa-circle-info me-1"></i>
                {{ trans('no-data') }}
            </div>
        {% else %}
            <div class="card shadow">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>{{ trans('code') }}</th>
                                <th>{{ trans('description') }}</th>
                                <th>{{ trans('expiration') }}</th>
                                <th class="text-center">{{ trans('active') }}</th>
                                <th class="text-center">{{ trans('paid') }}</th>
                                <th class="text-center">{{ trans('domiciled') }}</th>
                                <th class="text-center">{{ trans('print-bank-data') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in records %}
                                {% if not record.activa %}
                                    {% set rowClass = 'table-danger' %}
                                {% elseif record.pagado %}
                                    {% set rowClass = 'table-success' %}
                                {% elseif record.domiciliado %}
                                    {% set rowClass = 'table-info' %}
                                {% else %}
                                    {% set rowClass = '' %}
                                {% endif %}
                                <tr class="{{ rowClass }}">
                                    <td>
                                        <a href="NewFormaPago?codpago={{ record.codpago | url_encode }}"
                                           class="fw-semibold">
                                            {{ record.codpago }}
                                        </a>
                                    </td>
                                    <td>{{ record.descripcion }}</td>
                                    <td>
                                        {% if record.plazovencimiento %}
                                            {{ record.plazovencimiento }} {{ trans(record.tipovencimiento) }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if record.activa %}
                                            <i class="fa-solid fa-check text-success"></i>
                                        {% else %}
                                            <i class="fa-solid fa-xmark text-danger"></i>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if record.pagado %}
                                            <i class="fa-solid fa-check text-success"></i>
                                        {% else %}
                                            <i class="fa-solid fa-xmark text-muted"></i>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if record.domiciliado %}
                                            <i class="fa-solid fa-check text-success"></i>
                                        {% else %}
                                            <i class="fa-solid fa-xmark text-muted"></i>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if record.imprimir %}
                                            <i class="fa-solid fa-check text-success"></i>
                                        {% else %}
                                            <i class="fa-solid fa-xmark text-muted"></i>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
